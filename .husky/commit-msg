#!/usr/bin/env sh

message=$(head -n 1 "$1")

if printf "%s" "$message" | grep -Eq '^(Merge |Revert )'; then
  exit 0
fi

if ! printf "%s" "$message" | grep -Eq '^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'; then
  echo "Commit message must follow Conventional Commits."
  echo "Example: feat(auth): add agent token refresh"
  exit 1
fi
