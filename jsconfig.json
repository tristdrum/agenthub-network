{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "target": "esnext",
    "checkJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "maxNodeModuleJsDepth": 0,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/App.jsx",
    "src/Layout.jsx",
    "src/main.jsx",
    "src/pages.config.js",
    "src/components/**/*.js",
    "src/pages/**/*.jsx",
    "src/lib/**/*.js",
    "src/lib/**/*.jsx",
    "tests/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/vite-plugins",
    "src/components/ui",
    "src/api"
  ]
}
